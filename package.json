{
  "name": "typescript-effect-template",
  "version": "0.1.0",
  "private": true,
  "description": "Vite+ fullstack TypeScript starter centered on Effect v4 beta",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@effect/language-service": "0.86.1",
    "@effect/platform-node": "4.0.0-beta.66",
    "@effect/vitest": "4.0.0-beta.66",
    "@playwright/cli": "^0.1.13",
    "@playwright/test": "1.60.0",
    "@types/node": "25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "effect": "4.0.0-beta.66",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "8.0.12",
    "vite-plus": "0.1.21",
    "vitest": "4.1.6"
  },
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "vp run --recursive dev",
    "lint": "vp run --recursive lint",
    "check": "vp run --recursive check",
    "test": "vp run --recursive test",
    "build": "vp run --recursive build",
    "test:e2e": "vp run --filter @template/e2e test:e2e",
    "test:e2e:smoke": "vp run --filter @template/e2e test:e2e:smoke",
    "deps:check": "vp outdated"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
