				<Text><![CDATA[Case (     Container file extension = "jpg" Or Container file extension = "jpeg" ;          Case ( Container file size > 2*1024 ; "Warning" ; "") ;    Container file extension = "png" ;          Case ( Container file size > 2*1024 ; "Warning" ; "");    Container file extension = "mp4" ;          Case ( Container file size > 25*1024 ; "Warning" ; "");    Container file extension = "mp3" ;          Case ( Container file size > 5*1024 ; "Warning" ; "");    Container file extension = "pdf" ;          Case ( Container file size > 5*1024 ; "Warning" ; "");                  //All other file types         Case ( Container file size > 5*1024 ; "Warning" ; ""))]]></Text>
