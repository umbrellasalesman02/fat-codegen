				<Text><![CDATA[Let ( [   container_orgname_no_ext = getChar ( Container original filename ; 1 ; Position(Container original filename; "."; 1 ; PatternCount ( Container original filename ; "." ))-1);   container_expname_no_ext = container_orgname_no_ext & "_" & Case ( IsEmpty ( Original key ); PrimaryKey; Original key);   exported_filename = Case (hasMedia And Not PatternCount ( Source item type ; "sprig" ); container_expname_no_ext; container_orgname_no_ext)];   PrettifyDash ( exported_filename) )]]></Text>
