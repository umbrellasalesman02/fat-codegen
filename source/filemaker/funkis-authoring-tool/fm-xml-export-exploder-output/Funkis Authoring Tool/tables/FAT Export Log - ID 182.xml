			<Calculation>
				<TableOccurrenceReference id="1065250" name="FAT Export Log"></TableOccurrenceReference>
				<Text><![CDATA[Let ( [   expMode = Case (      ExportMode = "JSON" ; "JSON";     ExportMode = "TEXT" ; "Text JSON";     ExportMode = "Media update" ; "Media-update Text JSON";     ExportMode = "Media all" ; "Media-all Text JSON");   typeOfTask = Case (      Type of task = "sync"; "Content";     Type of task = "publish"; "Code Content";     Type of task = "publish-funkis-cloud"; "Funkis Cloud Delivery")];  typeOfTask & " - " & expMode ) /* jobTypesSCORM_12SCORM_2004WEB_LINKXAPIExample "["SCORM_12","XAPI"]typeOfTasksync - syncing new content from FAT to Funkis Cloud serverpublish - building a new package with both content from FAT and code from GitLab*/]]></Text>
