		<Field id="16" name="Tag Value JSON" fieldtype="Calculated" datatype="Text" comment="">
			<UUID modifications="24" userName="jensthorsen" accountName="jensthorsen" timestamp="2025-06-13T14:18:47">6FEAEFD5-0498-466D-AC88-257DBAE52F19</UUID>
			<AutoEnter alwaysEvaluate="False"></AutoEnter>
			<Storage storeCalculationResults="False" global="False" maxRepetitions="1">
				<LanguageReference name="Swedish" id="41"></LanguageReference>
			</Storage>
			<Calculation>
				<TableOccurrenceReference id="1065244" name="FAT Tag Value"></TableOccurrenceReference>
				<Text><![CDATA[JSONSetElement ( "{}" ; ["tag_id" ; Tag id ; JSONString ];["tag_text_id" ; TF TAG Name::PrimaryKey ; JSONString ];["tag_category" ; PrettifyDash (FAT Tag::Tag category) ; JSONString ];["tag_text_pure" ; TF TAG Name::Text ; JSONString ];["tag_text" ; PrettifyDash ( TF TAG Name::Text ) ; JSONString ];["valuelist_id" ; FAT Tag::List id for JSON ; JSONString ];["valuelistitem_id" ; FAT Tag::List item id for JSON ; JSONString ];["io_id" ; FAT IO @ List @ Tag::PrimaryKey ; JSONString ];["io_context" ; PrettifyDash ( IO Context) ; JSONString ];["new_io_context" ; FAT IO Value @ Page item @ Tag Value::IO Write as ; JSONString ];["logical_operator" ; Substitute ( Logical operator ;    ["AND" ; "&&" ];   ["OR" ; "||" ]); JSONString];["no_tag_behavior" ; Case ( IsEmpty ( Tag behaviour ) Or Tag behaviour="Mini"; "collapse" ; PrettifyDash (Tag behaviour )) ; JSONString ])]]></Text>
			</Calculation>
		</Field>
