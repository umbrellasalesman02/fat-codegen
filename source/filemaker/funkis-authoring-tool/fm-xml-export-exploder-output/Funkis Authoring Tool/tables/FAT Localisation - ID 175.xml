			<Storage storeCalculationResults="True" autoIndex="True" global="False" maxRepetitions="1">
				<LanguageReference name="Swedish" id="41"></LanguageReference>
			</Storage>
			<Calculation>
				<TableOccurrenceReference id="1065181" name="FAT Localisation"></TableOccurrenceReference>
				<Text><![CDATA[Case ( IsEmpty(Package id) And IsEmpty(Title localisation id) And Not IsEmpty ( Shared text localisation id ) ;         "Title";      Not IsEmpty ( Package id) And IsEmpty ( Shared text localisation id );        "Package";      IsEmpty ( Package id ) And Not IsEmpty ( Title localisation id ) And IsEmpty ( Shared text localisation id );             "Shared text" )]]></Text>
			</Calculation>
