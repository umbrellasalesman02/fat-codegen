		<Field id="46" name="Type of localisation" fieldtype="Calculated" datatype="Text" comment="Can be either &quot;Title&quot;, &quot;Package&quot; or &quot;Shared text&quot;">
			<UUID modifications="4" userName="jensthorsen" accountName="jensthorsen" timestamp="2024-11-16T10:10:34">75F64F0C-DCF2-4FE2-8460-FA2B00FBB148</UUID>
