				<Text><![CDATA[Let ([        j1_atv = "{" & Case ( ValueCount ( FAT ModifierValue @ List::Value JSON ) = 0 ; "" ;         Substitute ( List ( FAT ModifierValue @ List::Value JSON ) ; ¶ ; ", " ) & "" ) & "}";        j1 = JSONSetElement ( j1_atv ;          ["name"; JSON Friendly Name; JSONString];         ["id"; PrimaryKey; JSONString];         ["filter_name"; PrettifyDash (Filter name); JSONString];          ["template"; PrettifyDash (List template::Name); JSONString];          ["backend"; BackendJSON; JSONObject];          ["usage"; PrettifyDash (Usage type); JSONString]     );    j2 = Case (List of Lists = 1 ;          JSONSetElement ( j1 ; "values" ; "[" & Substitute ( List(FAT List item @ List of Lists::List Item JSON) ; ¶ ; ", ") & "]" ; JSONArray)         ;          JSONSetElement ( j1 ; "values" ; "[" & Substitute ( List(FAT List item::List Item JSON) ; ¶ ; ", ") & "]"; JSONArray)         )      ];    j2 )]]></Text>
			</Calculation>
