				<TableOccurrenceReference id="1065340" name="FAT Modifier Value"></TableOccurrenceReference>
				<Text><![CDATA[Let ( [    value0 = FAT Modifier Value::Value;    value1 = Substitute ( value0 ; "." ; "," );    value2 = Evaluate ( value1 );    value3 = GetAsText ( value2 );    prefix = Case ( Abs ( value2 )<1 And value2 ≠ 0; "0"; "" );    value4 = prefix & Substitute ( value3 ; "," ; "." )];   Case(value0 = ""; "0"; value4)      )]]></Text>
			</Calculation>
