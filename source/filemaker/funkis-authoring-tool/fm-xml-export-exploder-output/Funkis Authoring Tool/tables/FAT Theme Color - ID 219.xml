		<Field id="20" name="colorSwatch WebViewer" fieldtype="Calculated" datatype="Text" comment="Not visible in portals">
			<UUID modifications="7" userName="Jens Thorsen" accountName="jensthorsen" timestamp="2021-12-25T22:10:23">BDAE87CD-DB0D-4393-B7CA-34A1FF35A3E5</UUID>
