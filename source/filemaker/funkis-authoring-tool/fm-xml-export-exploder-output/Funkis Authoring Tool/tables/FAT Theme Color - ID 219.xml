			<Calculation>
				<TableOccurrenceReference id="1065519" name="FAT Theme Color"></TableOccurrenceReference>
				<Text><![CDATA[Let ( [    cR = HexToRGB ( Color Hex Value ; "R" );    cG = HexToRGB ( Color Hex Value ; "G" );    cB = HexToRGB ( Color Hex Value ; "B" )];TextColor ( TextSize (TextFont ( Char ( 61543 ) ; "Webdings" ); 256 ) ;RGB ( cR ; cG ; cB ) ) )]]></Text>
