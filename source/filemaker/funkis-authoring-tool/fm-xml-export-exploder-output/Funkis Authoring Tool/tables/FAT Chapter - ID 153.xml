		<Field id="13" name="Chapter JSON" fieldtype="Calculated" datatype="Text" comment="">
			<UUID modifications="47" userName="jensthorsen" accountName="jensthorsen" timestamp="2025-09-11T15:53:03">17ECFAE3-E70E-49B4-B73D-16D6EAA7FAE2</UUID>
			<AutoEnter alwaysEvaluate="False"></AutoEnter>
			<Storage storeCalculationResults="False" global="False" maxRepetitions="1">
				<LanguageReference name="Swedish" id="41"></LanguageReference>
			</Storage>
			<Calculation>
				<TableOccurrenceReference id="1065127" name="FAT Chapter"></TableOccurrenceReference>
				<Text><![CDATA[Let ( [json1 = "{" & Case ( ValueCount ( FAT ModifierValue @ Chapter::Value JSON ) = 0 ; "" ;         Substitute ( List ( FAT ModifierValue @ Chapter::Value JSON ) ; ¶ ; ", " ) & "" ) & "}";json3 = JSONSetElement ( json1 ;        ["id" ; PrimaryKey ; JSONString ] ;      ["context" ; Context ID ; JSONString ] ;      ["friendly_id" ; JSON friendly id ; JSONString ] ;      ["parent_id" ; JSON parent id ; JSONString ] ;      ["parent_type" ; Case ( FAT Package::Proxy type = "chapter" ; "title" ; "package" ) ; JSONString ] ;      ["type" ; "chapter" ; JSONString ] ;      ["title_txt_id" ; Header txt id ; JSONString ] ;      ["sub_title_1_txt_id" ; Sub header txt id ; JSONString ] ;      ["sub_title_2_txt_id" ; Sub header 2 txt id Legacy ; JSONString ] ;      ["tags" ; "[" & Substitute ( List (FAT Tag Value @ CH::Tag Value JSON) ; ¶ ; ", " ) & "]"; JSONArray ];      [ "score_value" ; "[" & Substitute ( List (FAT Score Value @ CH::Score Value JSON) ; ¶ ; ", " ) & "]" ; JSONArray ] ;      [ "score_condition" ; "[" & Substitute ( List (FAT Score Condititon @ CH::Score condition JSON) ; ¶ ; ", " ) & "]" ; JSONArray ] ;      ["number_of_links" ; Number of pages ; JSONNumber ];      ["sort_index" ; JSON sortIndex ; JSONNumber ];      ["hierarchy_level" ; Case ( IsEmpty ( FAT Title::Base project) ; Hierarchy level ; Hierarchy level - 1) ; JSONNumber ]   );json4 = Case ( Left ( Media Main Menu BG CH::Media JSON ; 1 )= "{" ;                 JSONSetElement ( json3 ; "main_menu_image" ; Media Main Menu BG CH::Media JSON ; JSONObject );                JSONSetElement ( json3 ; "main_menu_image" ; Media Main Menu BG CH::Media JSON ; JSONString )         );json5 = Case ( Left ( Media Main Menu FG CH::Media JSON ; 1 )= "{" ;                 JSONSetElement ( json4 ; "main_menu_foreground_image" ; Media Main Menu FG CH::Media JSON ; JSONObject );                JSONSetElement ( json4 ; "main_menu_foreground_image" ; Media Main Menu FG CH::Media JSON ; JSONString )         );json6 = Case ( Left ( Media Main Menu Icon CH::Media JSON ; 1 )= "{" ;                 JSONSetElement ( json5 ; "main_menu_icon" ; Media Main Menu Icon CH::Media JSON ; JSONObject );                JSONSetElement ( json5 ; "main_menu_icon" ; Media Main Menu Icon CH::Media JSON ; JSONString )         );json7 = Case ( FATversion > 3 ; JSONSetElement ( json6 ; "program_type" ; PrettifyDash (Package type::Program type) ; JSONString); json6 )];JSONFormatElements ( json7 ))]]></Text>
			</Calculation>
		</Field>
