		<Field id="27" name="Text Variable JSON" fieldtype="Calculated" datatype="Text" comment="Introduced in May 2025">
			<UUID modifications="25" userName="jensthorsen" accountName="jensthorsen" timestamp="2026-02-28T19:20:28">6082E552-75DE-4827-A7B0-F69841203EEC</UUID>
