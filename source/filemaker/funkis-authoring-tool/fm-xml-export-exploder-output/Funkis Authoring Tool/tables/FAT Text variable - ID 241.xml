			<Storage storeCalculationResults="False" global="False" maxRepetitions="1">
				<LanguageReference name="Unicode" id="2"></LanguageReference>
			</Storage>
			<Calculation>
				<TableOccurrenceReference id="1065760" name="FAT Text variable"></TableOccurrenceReference>
				<Text><![CDATA[Let (    [          // If text variable has input fields  data = field ID, otherwise data given by IO Data key     datakey =  Case ( IO Type @ Text variable::IO has fields;                        IO Data key;                       GetParenthesisValue(IO Data key)                     );     io_datakey =  Case ( IO Type Grouped by::IO has fields;                        Group by IO Data key;                       GetParenthesisValue(Group by IO Data key)                     );     grouped_by_io_json = JSONSetElement ( "{}" ;                                             ["io_datakey" ; io_datakey ; JSONString];                                             ["source_id" ; Group by IO ; JSONString];                                            ["io_context" ; Group by IO Context ; JSONString];                                            ["use_insights" ; Case(Group by IO Context="Title"; "yes"; "no") ; JSONString]                                          );   json = JSONSetElement ( "{}" ;              ["id"; PrimaryKey; JSONString];             ["name"; Friendly string; JSONString];             ["source_id"; Source id; JSONString];             ["source_type"; Source type; JSONString];             ["io_datakey"; datakey; JSONString];             ["io_context"; PrettifyUnderScore (IO Context); JSONString];             ["io_context_legacy"; IO Context legacy; JSONString];             ["default_text_id"; Default Text id; JSONString];             ["index"; Case ( IO Output = "Index"; Index; ""); JSONNumber];             ["filter" ; "[" & Substitute ( List (FAT IO Condition @ TV::IO condition JSON) ; ¶ ; ", " ) & "]" ; JSONArray];             ["sort_order" ; "[" & Substitute ( List (FAT IO SortOrder @ TV::IO sort order JSON) ; ¶ ; ", " ) & "]" ; JSONArray];             ["use_insights" ; Case(IO Context="Title"; "yes"; "no") ; JSONString];             ["grouped_by" ; grouped_by_io_json ; JSONObject];             ["separator"; Case (                                    IO Context = "Title"; "table";                                   IO Output = "Numbered list"; "ol_li";                                   IO Output = "Bulleted list"; "ul_li";                                   IO Output = "New line"; "br";                                   IO Output = "Comma separated"; "comma";                                   IO Output = "Table"; "table";                                   IO Output = "Average value"; "mean";                                   IO Output = "Median value"; "median";                                   IO Output = "Variation"; "coefficientOfVariation"              ); JSONString];             ["manuscript" ; Manuscript ; JSONString];             ["loading_text" ; Loading text ; JSONString];             ["background_context" ; Background context ; JSONString]     )];      json )]]></Text>
			</Calculation>
		</Field>
