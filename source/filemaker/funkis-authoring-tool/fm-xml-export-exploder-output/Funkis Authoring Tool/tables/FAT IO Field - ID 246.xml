		<Field id="17" name="IO Field JSON" fieldtype="Calculated" datatype="Text" comment="">
			<UUID modifications="24" userName="jensthorsen" accountName="jensthorsen" timestamp="2025-11-04T19:37:52">787C3C23-01A0-4616-83C2-DA6F0E303D29</UUID>
			<AutoEnter alwaysEvaluate="False"></AutoEnter>
			<Storage storeCalculationResults="False" global="False" maxRepetitions="1">
				<LanguageReference name="Swedish" id="41"></LanguageReference>
			</Storage>
			<Calculation>
				<TableOccurrenceReference id="1065815" name="FAT IO Field"></TableOccurrenceReference>
				<Text><![CDATA[Let ( [   json1 = Case(IsEmpty(Linked IO Field id);          JSONSetElement ( "{}" ;           ["name" ; PrettifyUnderScore (Name) ; JSONString ];          ["id" ; PrimaryKey ; JSONString ];          ["label_input" ; Label input ; JSONString ];          ["label_output" ; Label output ; JSONString ];          ["hint_text" ; Hint ; JSONString ];          ["min_chars" ; Minimum characters ; JSONNumber ];          ["max_chars" ; Maximum characters ; JSONNumber ];          ["rows" ; Number of rows ; JSONNumber ];          ["required" ; Case(Input required = "Yes"; 1; 0) ; JSONBoolean ];          ["type_id" ; Type ; JSONString ];          ["type_friendly_id" ; PrettifyDash (IO Field Type::Name) ; JSONString ];          ["value_type" ; PrettifyDash (IO Field Type::Value type) ; JSONString ];          ["list_id" ; List id ; JSONString ];          ["sort_index" ; SortIndex ; JSONNumber ];          ["insight_ai_aspect_list";  Aspect List id ; JSONString]         );          // Takes everything from IO from another field                    JSONSetElement ( "{}" ;           ["name" ; PrettifyUnderScore (FAT IO Field Linked @ IO Field::Name) ; JSONString ];          ["id" ; FAT IO Field Linked @ IO Field::PrimaryKey ; JSONString ];          ["label_input" ; FAT IO Field Linked @ IO Field::Label input ; JSONString ];          ["label_output" ; FAT IO Field Linked @ IO Field::Label output ; JSONString ];          ["hint_text" ; FAT IO Field Linked @ IO Field::Hint ; JSONString ];          ["min_chars" ; FAT IO Field Linked @ IO Field::Minimum characters ; JSONNumber ];          ["max_chars" ; FAT IO Field Linked @ IO Field::Maximum characters ; JSONNumber ];          ["rows" ; FAT IO Field Linked @ IO Field::Number of rows ; JSONNumber ];          ["required" ; Case(FAT IO Field Linked @ IO Field::Input required = "Yes"; 1; 0) ; JSONBoolean ];          ["type_id" ; FAT IO Field Linked @ IO Field::Type ; JSONString ];          ["type_friendly_id" ; PrettifyDash (IO Field Type @ Linked IO::Name) ; JSONString ];          ["value_type" ; PrettifyDash (IO Field Type @ Linked IO::Value type) ; JSONString ];          ["list_id" ; FAT IO Field Linked @ IO Field::List id; JSONString ];          ["sort_index" ; SortIndex ; JSONNumber ];          ["insight_ai_aspect_list";  FAT IO Field Linked @ IO Field::Aspect List id ; JSONString]         )    )];//If field is a list but no list is chosen Funkis Player crashes completely.Case ( IO Field Type @ Linked IO::Value type = "List" And IsEmpty ( FAT IO Field Linked @ IO Field::List id ) ; "{}"; json1)  )]]></Text>
			</Calculation>
		</Field>
