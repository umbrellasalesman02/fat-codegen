				<Text><![CDATA[// An identical JSON is also created in the Title List (except Input field values and IO Value conditions).// If this JSON needs to change - don't forget to change the List Item JSON too.Let ([  j0 =  "[" & Substitute ( FAT IO Value @ Page item::IO Insight Selected Aspect List items  ; "¶" ; "\",\"" ) & "]" ;  j00 = Substitute ( j0 ; ["[" ; "[\""] ; ["]" ; "\"]"] );   j1 = JSONSetElement ( "{}" ;       ["friendly_label_id"; IO Block Template @ IO Value::Label Friendly id; JSONString];      ["id"; IO id; JSONString];      ["type"; IO Type @ IO Value::QuidType; JSONString];      ["context"; PrettifyUnderScore (IO Context); JSONString];      ["read_filter"; PrettifyUnderScore (IO Read filter); JSONString];      ["write_as"; PrettifyUnderScore (Substitute(IO Write as; ["My "; ""];["Session"; "member"])); JSONString];      ["function"; PrettifyDash ( IO Block Template @ IO Value::Function ); JSONString];      ["input_fields" ; "[" & Substitute ( List (FAT IO Field Value @ IO Value PI::Field JSON) ; ¶ ; ", " ) & "]" ; JSONArray];      ["categorization_field_id" ; IO Field id List sync ; JSONString];      ["filter" ; "[" & Substitute ( List (FAT IO Condition @ IO Value PI::IO condition JSON) ; ¶ ; ", " ) & "]" ; JSONArray];      ["sort_order" ; "[" & Substitute ( List (FAT IO SortOrder @ IO Value PI::IO sort order JSON) ; ¶ ; ", " ) & "]" ; JSONArray];      ["insight_aspect_field_id" ; IO Insight Aspect Field ; JSONString];      ["insight_aspect_selected_list_items" ; j00 ; JSONArray]   );   j2 = Case ( IsEmpty (IO Index); j1; JSONSetElement ( j1 ; "index" ; IO Index ; JSONNumber )) ;   j3 = Case ( IsEmpty (FAT IO @ Page item::Text 1 id); j2; JSONSetElement ( j2 ; "text_1_id" ; FAT IO @ Page item::Text 1 id ; JSONString ));   j4 = Case ( IsEmpty (FAT IO @ Page item::Text 2 id); j3; JSONSetElement ( j3 ; "text_2_id" ; FAT IO @ Page item::Text 2 id ; JSONString )) ;   j5 = Case ( IsEmpty (FAT IO @ Page item::IO List id); j4; JSONSetElement ( j4 ; "io_group" ; FAT List @ IO Page item::List JSON ; JSONObject )) ]; j5)]]></Text>
			</Calculation>
		</Field>
