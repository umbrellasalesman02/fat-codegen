		<Field id="15" name="Page JSON" fieldtype="Calculated" datatype="Text" comment="">
			<UUID modifications="58" userName="jensthorsen" accountName="jensthorsen" timestamp="2025-09-10T16:15:46">7ACABBA4-13FB-49BC-B417-9F92CF7DE236</UUID>
			<AutoEnter alwaysEvaluate="False"></AutoEnter>
			<Storage storeCalculationResults="False" global="False" maxRepetitions="1">
				<LanguageReference name="Swedish" id="41"></LanguageReference>
			</Storage>
			<Calculation>
				<TableOccurrenceReference id="1065128" name="FAT Page"></TableOccurrenceReference>
				<Text><![CDATA[Let ( [json1 = "{" & Case ( ValueCount ( FAT ModifierValue @ Page::Value JSON ) = 0 ; "" ;         Substitute ( List ( FAT ModifierValue @ Page::Value JSON ) ; ¶ ; ", " ) & "" ) & "}";json3 = JSONSetElement ( json1 ;        ["id" ; PrimaryKey ; JSONString ] ;      ["context" ; Context ID ; JSONString ] ;      ["friendly_id" ; JSON friendly id ; JSONString ] ;      ["parent_id" ; JSON parent id ; JSONString ] ;      ["page_type" ; Page type ; JSONString];      ["parent_type" ; Case ( FAT Package::Proxy type = "page" ; "title" ; FAT Chapter::Proxy type = "page"; Case ( Package type::Name = "Site"; "chapter" ; "package" ); "chapter" ) ; JSONString ] ;      ["type" ; "page" ; JSONString ] ;      ["title_txt_id" ; Header txt id ; JSONString ] ;      ["sub_title_1_txt_id" ; Sub header 1 txt id ; JSONString ] ;      ["sub_title_2_txt_id" ; Sub header 2 txt id ; JSONString ] ;      ["tags" ; "[" & Substitute ( List (FAT Tag Value @ PG::Tag Value JSON) ; ¶ ; ", " ) & "]"; JSONArray ];      [ "score_value" ; "[" & Substitute ( List (FAT Score Value @ PG::Score Value JSON) ; ¶ ; ", " ) & "]" ; JSONArray ] ;      [ "score_condition" ; "[" & Substitute ( List (FAT Score Condititon @ PG::Score condition JSON) ; ¶ ; ", " ) & "]" ; JSONArray ] ;      ["number_of_page_items" ; Number of page items ; JSONNumber ];      ["sort_index" ; JSON sortIndex ; JSONNumber ];      ["hierarchy_level" ; Case ( IsEmpty ( FAT Title::Base project) ; Hierarchy level ; Hierarchy level - 1) ; JSONNumber ]   );json4 = Case ( Left ( Media Main Menu BG CH::Media JSON ; 1 )= "{" ;                 JSONSetElement ( json3 ; "main_menu_image" ; Media Main Menu Image PG::Media JSON ; JSONObject );                JSONSetElement ( json3 ; "main_menu_image" ; Media Main Menu Image PG::Media JSON ; JSONString )         );json5 = Case ( FATversion > 3 ; JSONSetElement ( json4 ; "program_type" ; PrettifyDash (Package type::Program type) ; JSONString); json4 )];JSONFormatElements ( json5 ))]]></Text>
			</Calculation>
		</Field>
