		<Step hash="6FF64C86F23B2F1B04962CD24E1CE973" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[Let ( [    //input    lc=$localisation_code;    title = $title_id;    status = $status;    package = $package_id;    shared_localisation = $shared_localisation;    //count field    cf = #F ( FAT Text::PrimaryKey );        //from table    table = #T ( FAT Text::PrimaryKey);    //where fields    lc_f = #F ( FAT Text::Localisation code );    status_f = #F ( FAT Text::Status );    title_f = #F ( FAT Text::Title id );    package_f = #F ( FAT Text::Package id );    ~query = Case(       package = "" And Not shared_localisation;           "SELECT COUNT(~cf) FROM ~table WHERE ~lc_f=? AND ~title_f=? AND ~status_f=?";       package = "" And shared_localisation;           "SELECT COUNT(~cf) FROM ~table WHERE ~lc_f=? AND ~title_f=? AND ~status_f=? AND ~package_f IS NULL";          "SELECT COUNT(~cf) FROM ~table WHERE ~lc_f=? AND ~title_f=? AND ~status_f=? AND ~package_f=?"    );~sqlQuery = Substitute (  ~query ;             ["~cf"; cf];            ["~table"; table];            ["~lc_f"; lc_f];            ["~title_f"; title_f];            ["~package_f"; package_f];            ["~status_f"; status_f] )   ];Case(package = "";     ExecuteSQL (~sqlQuery ; "" ; "" ; lc; title; status );    ExecuteSQL (~sqlQuery ; "" ; "" ; lc; title; status; package ))//~sqlQuery & ", " & lc & ", " & title & ", " & status )]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$num_of_texts"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
