		<Step hash="7AA235717CDD10D2E7564A94B1B363E7" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[Let ( [    //input    lc=FAT Title::gCurrentLocalisationCode;    title = FAT Title::PrimaryKey;    status = $status;    package = FAT Text::gPackage;    //count field    cf = #F ( FAT Text::PrimaryKey );        //from table    table = #T ( FAT Text::PrimaryKey);    //where fields    lc_f = #F ( FAT Text::Localisation code );    status_f = #F ( FAT Text::Status );    title_f = #F ( FAT Text::Title id );    package_f = #F ( FAT Text::Package id );    ~query = Case(package = "";        "SELECT COUNT(~cf) FROM ~table WHERE ~lc_f=? AND ~title_f=? AND ~status_f=?";       "SELECT COUNT(~cf) FROM ~table WHERE ~lc_f=? AND ~title_f=? AND ~status_f=? AND ~package_f=?"    );~sqlQuery = Substitute (  ~query ;             ["~cf"; cf];            ["~table"; table];            ["~lc_f"; lc_f];            ["~title_f"; title_f];            ["~package_f"; package_f];            ["~status_f"; status_f] )   ];Case(package = "";     ExecuteSQL (~sqlQuery ; "" ; "" ; lc; title; status );    ExecuteSQL (~sqlQuery ; "" ; "" ; lc; title; status; package ))//~sqlQuery & ", " & lc & ", " & title & ", " & status )]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$num_of_texts"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
