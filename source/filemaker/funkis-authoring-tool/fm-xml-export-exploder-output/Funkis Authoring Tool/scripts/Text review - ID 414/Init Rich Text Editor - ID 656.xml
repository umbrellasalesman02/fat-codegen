		<Step hash="C5C614360BB679DA3A4614A10B8B535B" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[/* HTML Parameters */ Let ( [originalText = JSONSetElement ( "{}" ;                      ["id" ; "1" ; JSONString];                    ["label" ; "Original text" ; JSONString];                    ["html" ; False  ; JSONBoolean ];                    ["value" ; sanitizeHTML(FAT Text @ Translation::Text); JSONString ];                    ["maxchars" ; 0 ; JSONNumber ]                 ) ;translatedText = JSONSetElement ( "{}" ;                      ["id" ; "2" ; JSONString];                    ["label" ; "Translated text" ; JSONString];                    ["html" ; True  ; JSONBoolean ];                    ["value" ; sanitizeHTML(FAT Text translated::Text); JSONString ];                    ["maxchars" ; 0 ; JSONNumber ]                 ) ;textArr =  "[" & originalText & "," & translatedText & "]";json = JSONSetElement ( "{}" ;              ["environment" ; Case ( Platform="WebDirect"; "web"; "FileMaker") ; JSONString];             ["record-id" ; Get(recordID) ; JSONNumber];             ["localisation_mode" ; "translate"; JSONString];             ["edit_mode" ; "textTranslate"; JSONString];             ["localisation_code" ; $$localisation code ; JSONString];             ["texts" ; textArr ; JSONArray]        )];json)]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$HTML_JSON"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
