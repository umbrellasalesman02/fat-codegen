<Script>
	<ScriptReference id="101" name="Test for Missing Google API Key"></ScriptReference>
	<ObjectList membercount="9">
		<Step hash="CA3CD9C342112C89D1B39AAC7203E73D" id="68" name="If" enable="True">
			<Options>16384</Options>
			<ParameterValues membercount="1">
				<Parameter type="Calculation">
					<Calculation datatype="7" position="0">
						<Calculation>
							<Text><![CDATA[IsEmpty(Variables::Google API key)]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="7F9F4D41DAE2074D0BA290020D741907" id="87" name="Show Custom Dialog" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="5">
				<Parameter type="Title">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA["There is a problem"]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Message">
					<Calculation datatype="1" position="1">
						<Calculation>
							<Text><![CDATA["You seem to be missing the Google API Key. If you don't have one, click 'Get One'. Otherwise paste it into the Google API Key field."]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Button1" value="OK">
					<Boolean type="Commit" value="True"></Boolean>
				</Parameter>
				<Parameter type="Button2" value="Get One">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
				<Parameter type="Button3">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="EF4820B18812E2EF50ACED3E3448A1CD" id="68" name="If" enable="True">
			<Options>16384</Options>
			<ParameterValues membercount="1">
				<Parameter type="Calculation">
					<Calculation datatype="7" position="0">
						<Calculation>
							<Text><![CDATA[Get(lastMessageChoice)=1]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="F430D539253EF5331321FACAD3C34F2D" id="17" name="Go to Field" enable="True">
			<Options>4097</Options>
			<ParameterValues membercount="2">
				<Parameter type="Boolean">
					<Boolean type="Select/perform" id="4096" value="True"></Boolean>
				</Parameter>
				<Parameter type="FieldReference">
					<FieldReference id="6" name="Google API key">
						<repetition>
							<Calculation datatype="1" position="10">
								<Calculation>
									<Text><![CDATA[1]]></Text>
								</Calculation>
							</Calculation>
						</repetition>
						<TableOccurrenceReference id="1065151" name="Variables"></TableOccurrenceReference>
					</FieldReference>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="597B130284385895A4D761911E8351AB" id="90" name="Halt Script" enable="True">
		</Step>
		<Step hash="61092910E15891F486EA9314A07E2081" id="69" name="Else" enable="True">
		</Step>
		<Step hash="70EC0E34D5B6E6087BABD985BE4CF790" id="1" name="Perform Script" enable="True">
			<Options>16448</Options>
			<ParameterValues membercount="2">
				<Parameter type="List">
					<List name="From list" value="1">
						<ScriptReference id="98" name="Open Google URLs"></ScriptReference>
					</List>
				</Parameter>
				<Parameter type="Parameter">
					<Parameter>
						<Calculation datatype="1" position="0">
							<Calculation>
								<Text><![CDATA["API Console"]]></Text>
							</Calculation>
						</Calculation>
					</Parameter>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="EEFDA9D701E7807CCDF3850A21A6CCC3" id="70" name="End If" enable="True">
		</Step>
		<Step hash="2A93B232ADA4BD678E9CF8994F130AA1" id="70" name="End If" enable="True">
		</Step>
	</ObjectList>
</Script>
