		<Step hash="8F5A2A5BCBE0129B7C07A4AE94C5AA70" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[/* HTML Parameters */ Let (        [         i = 1;         trans = Case ( FAT Title::gViewTranslatedLanguage ; " TRANS" ; "" );         localisation_mode = Case ( FAT Title::gViewTranslatedLanguage; "translate"; "original");         localisation_code = $$localisation_code;              LKjson2 = JSONSetElement ( "{}"  ;             ["label" ; "Link header" ; JSONString];             ["id" ; "2" ; JSONString];             ["html" ; True ; JSONBoolean];             ["maxchars" ; 10000 ; JSONNumber];             ["value" ; sanitizeHTML ( GetField("TF LK 1" & trans & "::Text") ) ; JSONString]          );        LKjson3 = JSONSetElement ( "{}"  ;             ["label" ; "Link body" ; JSONString];             ["id" ; "3" ; JSONString];             ["html" ; True ; JSONBoolean];             ["maxchars" ; 10000 ; JSONNumber];             ["value" ; sanitizeHTML ( GetField("TF LK 2" & trans & "::Text") ) ; JSONString]          );         LKtextArr = "[" & LKjson2 & "," & LKjson3  & "]";                    LKjsonResult = JSONSetElement ( "{}" ;                       ["environment" ; Case ( Platform="WebDirect"; "web"; "FileMaker") ; JSONString];                      ["record-id" ; Get(recordID) ; JSONNumber];                      ["localisation_mode" ; localisation_mode; JSONString];                      ["edit_mode" ; "titleLink"; JSONString];                      ["localisation_code" ; localisation_code ; JSONString];                      ["texts" ; LKtextArr ; JSONArray]               )               ];      JSONFormatElements ( LKjsonResult))]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$Link_HTML_JSON"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
