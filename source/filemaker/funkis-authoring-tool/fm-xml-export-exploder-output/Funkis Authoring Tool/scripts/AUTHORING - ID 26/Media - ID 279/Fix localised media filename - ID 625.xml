<Script>
	<ScriptReference id="625" name="Fix localised media filename"></ScriptReference>
	<ObjectList membercount="12">
		<Step hash="4A137B0961D668C598D4BD33CF828E1C" id="89" name="# (comment)" enable="True">
			<Options>4</Options>
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment value="Set the file name of localised media to the original filename + localisation code"></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="1EB61763C76C1F16D81EDF5CB50FD2AD" id="89" name="# (comment)" enable="True">
			<Options>4</Options>
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment value="This scipt is called from a script trigger when container is modified"></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="D80800A03A1C08C4080F4201D15BF69A" id="141" name="Set Variable" enable="False">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[FAT Media @ Trans::gRenameFile & "_" & FAT Media @ Trans::Localisation code]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$new_filename"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="DD197E6F3886B785B6ADCF58F9178021" id="68" name="If" enable="True">
			<Options>16384</Options>
			<ParameterValues membercount="1">
				<Parameter type="Calculation">
					<Calculation datatype="7" position="0">
						<Calculation>
							<Text><![CDATA[IsEmpty ( FAT Media @ Trans::Media container )]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="AC19DEBDE9F90D4F6C20DC46214D6191" id="89" name="# (comment)" enable="True">
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="9FAE98D0B9AAD15CE20145C0C6F476AE" id="69" name="Else" enable="True">
		</Step>
		<Step hash="972BCB5A1CCB04BFC40C8042772A6A69" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[FAT Media @ Trans::gRenameFile]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$new_filename"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="9C91A41B5C13C5E7940E287792E1A8F2" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[Lower ( FAT Media @ Trans::Container file extension )]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$filename_extension"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="94528ED6F099092F09E8D8FB94263A98" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[$new_filename & "." &  $filename_extension]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$new_filename"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="CEE4085D59C9B63DFA03212FBE739746" id="76" name="Set Field" enable="True">
			<Options>16385</Options>
			<ParameterValues membercount="2">
				<Parameter type="FieldReference">
					<FieldReference id="9" name="Media container">
						<repetition>
							<Calculation datatype="1" position="10">
								<Calculation>
									<Text><![CDATA[1]]></Text>
								</Calculation>
							</Calculation>
						</repetition>
						<TableOccurrenceReference id="1065464" name="FAT Media @ Trans"></TableOccurrenceReference>
					</FieldReference>
				</Parameter>
				<Parameter type="Calculation">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA[Base64Decode(Base64Encode(FAT Media @ Trans::Media container); $new_filename)]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="DE75CC64A4BDEEF926965F9E7365262F" id="70" name="End If" enable="True">
		</Step>
		<Step hash="B8BD09311C765C97441CDDFA19DCF31E" id="75" name="Commit Records/Requests" enable="True">
			<Options>128</Options>
			<ParameterValues membercount="3">
				<Parameter type="Boolean">
					<Boolean type="Skip data entry validation" id="256" value="False"></Boolean>
				</Parameter>
				<Parameter type="Boolean">
					<Boolean type="With dialog" id="128" value="False"></Boolean>
				</Parameter>
				<Parameter type="Boolean">
					<Boolean type="Force Commit" id="512" value="False"></Boolean>
				</Parameter>
			</ParameterValues>
		</Step>
	</ObjectList>
</Script>
