			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[GetThumbnail(  FAT Media::Media container;   Case ( $width>0 ; $width ; GetWidth ( FAT Media::Media container )) ;  Case ( $height>0 ; $height ; GetHeight ( FAT Media::Media container )) )]]></Text>
							</Calculation>
						</Calculation>
