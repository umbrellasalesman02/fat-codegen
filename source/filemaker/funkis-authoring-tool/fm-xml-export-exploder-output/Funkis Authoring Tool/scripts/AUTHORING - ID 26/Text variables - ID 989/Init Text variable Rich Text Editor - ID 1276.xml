		<Step hash="F79082DEFB504A1A1DF341C18277FD77" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[/* HTML Parameters */ Let (        [         i = 1;         localisation_mode = "original";              TVjson1 = JSONSetElement ( "{}" ;              ["label" ; "Manuscript" ; JSONString];             ["id" ; "1" ; JSONString];             ["html" ; True ; JSONBoolean];             ["maxchars" ; 100000 ; JSONNumber];             ["value" ; sanitizeHTML ( FAT Text variable::Manuscript ) ; JSONString]          );        TVjson2 = JSONSetElement ( "{}"  ;             ["label" ; "Loading text" ; JSONString];             ["id" ; "2" ; JSONString];             ["html" ; False ; JSONBoolean];             ["maxchars" ; 10000 ; JSONNumber];             ["value" ; sanitizeHTML ( FAT Text variable::Loading text ) ; JSONString]          );        TVjson3 = JSONSetElement ( "{}"  ;             ["label" ; "Background context" ; JSONString];             ["id" ; "3" ; JSONString];             ["html" ; True ; JSONBoolean];             ["maxchars" ; 100000 ; JSONNumber];             ["value" ; sanitizeHTML ( FAT Text variable::Background context ) ; JSONString]          );         TVtextArr = "[" & TVjson1 & "," & TVjson2 & "," & TVjson3 & "]";                    TVjsonResult = JSONSetElement ( "{}" ;                       ["environment" ; Case ( Platform="WebDirect"; "web"; "FileMaker") ; JSONString];                      ["record-id" ; Get(recordID) ; JSONNumber];                      ["localisation_mode" ; localisation_mode; JSONString];                      ["edit_mode" ; "textVariable"; JSONString];                      ["texts" ; TVtextArr ; JSONArray]               )               ];      JSONFormatElements ( TVjsonResult)      //LTjsonResult)]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$Text_variable_HTML_JSON"></Name>
					<repetition>
