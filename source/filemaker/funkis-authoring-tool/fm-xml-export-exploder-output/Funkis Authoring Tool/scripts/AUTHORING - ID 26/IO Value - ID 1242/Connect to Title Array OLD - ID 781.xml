<Script>
	<ScriptReference id="781" name="Connect to Title Array OLD"></ScriptReference>
	<ObjectList membercount="12">
		<Step hash="E34D22022E1E4A115368B553C8CFB560" id="89" name="# (comment)" enable="True">
			<Options>4</Options>
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment value="This script is called from a onModifiy script trigger on the IO Id field"></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="A8971C094444A068CFEA1B5828102394" id="89" name="# (comment)" enable="True">
			<Options>4</Options>
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment value="If the IO is designed to use a specific Title Content Array - this script adds the TCA to the page item."></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="6AB264ECCD0664C9226F0AD87023EA1D" id="89" name="# (comment)" enable="True">
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="D54A13B1DFC034E8184A1E85F50D7CE0" id="87" name="Show Custom Dialog" enable="True">
			<Options>16389</Options>
			<ParameterValues membercount="5">
				<Parameter type="Title">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA["Inform sysadmin if this dialog appears! "]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Message">
					<Calculation datatype="1" position="1">
						<Calculation>
							<Text><![CDATA["Script = Connect to Title Array"]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Button1" value="OK">
					<Boolean type="Commit" value="True"></Boolean>
				</Parameter>
				<Parameter type="Button2">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
				<Parameter type="Button3">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="1AAC68DCD482577E40B6C0C881E6A50A" id="89" name="# (comment)" enable="True">
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="074F0E60800E6252EC3E38D35958FF3A" id="68" name="If" enable="True">
			<Options>16384</Options>
			<ParameterValues membercount="1">
				<Parameter type="Calculation">
					<Calculation datatype="7" position="0">
						<Calculation>
							<Text><![CDATA[FAT Block @ Page item::List enabled]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="A12C1B491DBFB42D8ECCCBEBFB7A8DD4" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[FAT IO @ Page item::List id]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$tca_id"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="37E261E55C8DBE197983A12270FF9BAF" id="68" name="If" enable="True">
			<Options>16384</Options>
			<ParameterValues membercount="1">
				<Parameter type="Calculation">
					<Calculation datatype="7" position="0">
						<Calculation>
							<Text><![CDATA[$tca_id ≠ ""]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="C9BEADC4AF4492BF2B3D8D7C2ED2AC64" id="76" name="Set Field" enable="True">
			<Options>16385</Options>
			<ParameterValues membercount="2">
				<Parameter type="FieldReference">
					<FieldReference id="92" name="List id">
						<repetition>
							<Calculation datatype="1" position="10">
								<Calculation>
									<Text><![CDATA[1]]></Text>
								</Calculation>
							</Calculation>
						</repetition>
						<TableOccurrenceReference id="1065129" name="FAT Page item"></TableOccurrenceReference>
					</FieldReference>
				</Parameter>
				<Parameter type="Calculation">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA[$tca_id]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="BA9ADEB5EA068963C7348CBEC6A78F90" id="87" name="Show Custom Dialog" enable="True">
			<Options>16389</Options>
			<ParameterValues membercount="5">
				<Parameter type="Title">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA["Title Content Array Set"]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Message">
					<Calculation datatype="1" position="1">
						<Calculation>
							<Text><![CDATA["This IO uses a Title Content Array that now has been applied to the page item."]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Button1" value="OK">
					<Boolean type="Commit" value="True"></Boolean>
				</Parameter>
				<Parameter type="Button2">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
				<Parameter type="Button3">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="168B959943A6C5DE1C6A988A631F5892" id="70" name="End If" enable="True">
		</Step>
		<Step hash="2F25CDF5020F562210334978EF9BC0BF" id="70" name="End If" enable="True">
		</Step>
	</ObjectList>
</Script>
