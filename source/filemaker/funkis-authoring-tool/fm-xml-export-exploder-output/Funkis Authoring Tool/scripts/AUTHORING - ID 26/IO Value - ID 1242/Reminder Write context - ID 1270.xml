<Script>
	<ScriptReference id="1270" name="Reminder Write context"></ScriptReference>
	<ObjectList membercount="8">
		<Step hash="1846EE2DEEF51D271BCFCEBF89F8E262" id="89" name="# (comment)" enable="True">
			<Options>4</Options>
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment value="Called from an onModify script trigger in IO Value Page item card window&#13;The purpose is to warn the user to set the correct write context if they set a field to &quot;Write&quot; "></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="38480D7F6927D07F26C879E8408BDF15" id="89" name="# (comment)" enable="True">
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="EB872744B11A224E8685965CB2066D47" id="68" name="If" enable="True">
			<Options>16384</Options>
			<ParameterValues membercount="1">
				<Parameter type="Calculation">
					<Calculation datatype="7" position="0">
						<Calculation>
							<Text><![CDATA[FAT IO Field Value @ Page item::Field mode = "Write"]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="B4DEE6603191F020D3B3E55243847651" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[FAT IO Value @ Page item Current::IO Read filter]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$io_read_context"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="BA6C55BA2000F52419870B5B05DCD398" id="76" name="Set Field" enable="True">
			<Options>16385</Options>
			<ParameterValues membercount="2">
				<Parameter type="FieldReference">
					<FieldReference id="45" name="IO Write as">
						<repetition>
							<Calculation datatype="1" position="10">
								<Calculation>
									<Text><![CDATA[1]]></Text>
								</Calculation>
							</Calculation>
						</repetition>
						<TableOccurrenceReference id="1065873" name="FAT IO Value @ Page item Current"></TableOccurrenceReference>
					</FieldReference>
				</Parameter>
				<Parameter type="Calculation">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA[$io_read_context]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="095C28F6640829FFBB1C2F3F2BB785D0" id="1" name="Perform Script" enable="True">
			<Options>16448</Options>
			<ParameterValues membercount="2">
				<Parameter type="List">
					<List name="From list" value="1">
						<ScriptReference id="1234" name="CheckIOAccessRights CL"></ScriptReference>
					</List>
				</Parameter>
				<Parameter type="Parameter">
					<Parameter>
						<Calculation datatype="1" position="0">
							<Calculation>
								<Text><![CDATA[SetProperty ( "io_id" ; FAT IO Value @ Page item Current::IO id )]]></Text>
							</Calculation>
						</Calculation>
					</Parameter>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="2D341458091BBE0ABB1D761E735A04D2" id="87" name="Show Custom Dialog" enable="False">
			<Options>16389</Options>
			<ParameterValues membercount="5">
				<Parameter type="Title">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA["Attention, please!"]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Message">
					<Calculation datatype="1" position="1">
						<Calculation>
							<Text><![CDATA["You set a field to \"Write\" on an IO output block.¶¶Now, make sure to set the correct \"Write as\" context on this IO!"]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Button1" value="OK">
					<Boolean type="Commit" value="True"></Boolean>
				</Parameter>
				<Parameter type="Button2">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
				<Parameter type="Button3">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="BF62CE4E65F05F24F5C7B3DFB7832684" id="70" name="End If" enable="True">
		</Step>
	</ObjectList>
</Script>
