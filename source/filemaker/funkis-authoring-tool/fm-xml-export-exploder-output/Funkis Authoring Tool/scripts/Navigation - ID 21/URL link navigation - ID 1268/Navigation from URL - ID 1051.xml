				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[Let (   [   url = $url;    pos_start = Position ( url ; "script=" ; 0 ; 1 );    pos_end = Position ( url ; "&param=" ; 0 ; 1 );    script = Middle ( url ; pos_start + 7 ; pos_end -  pos_start- 7)   ];script )]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$script_name"></Name>
