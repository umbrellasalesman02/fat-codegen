<Script>
	<ScriptReference id="1237" name="Copy text in textfields"></ScriptReference>
	<ObjectList membercount="4">
		<Step hash="A84FDCFF4A221529CFE550EFCC15F156" id="89" name="# (comment)" enable="True">
			<Options>4</Options>
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment value="This script is called from a button in Page item layout"></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="59B6898B736E5EF08DD2B6CCF1E52439" id="89" name="# (comment)" enable="True">
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="7C9E7BB00DCDD3DAD84E85BEB600B647" id="76" name="Set Field" enable="True">
			<Options>16385</Options>
			<ParameterValues membercount="2">
				<Parameter type="FieldReference">
					<FieldReference id="65" name="gCopyHTMLText">
						<repetition>
							<Calculation datatype="1" position="10">
								<Calculation>
									<Text><![CDATA[1]]></Text>
								</Calculation>
							</Calculation>
						</repetition>
						<TableOccurrenceReference id="1065151" name="Variables"></TableOccurrenceReference>
					</FieldReference>
				</Parameter>
				<Parameter type="Calculation">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA[FAT Page item::HTML JSON Parameters]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="5F046D29FCA2F6AFEEAEF796BD733539" id="87" name="Show Custom Dialog" enable="True">
			<Options>16389</Options>
			<ParameterValues membercount="5">
				<Parameter type="Title">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA["All texts copied successfully"]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Message">
					<Calculation datatype="1" position="1">
						<Calculation>
							<Text><![CDATA["The texts for this " & $target & " are copied successfully. You can now paste them on to any other " & $target & "."]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
				<Parameter type="Button1" value="OK">
					<Boolean type="Commit" value="True"></Boolean>
				</Parameter>
				<Parameter type="Button2">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
				<Parameter type="Button3">
					<Boolean type="Commit" value="False"></Boolean>
				</Parameter>
			</ParameterValues>
		</Step>
	</ObjectList>
</Script>
