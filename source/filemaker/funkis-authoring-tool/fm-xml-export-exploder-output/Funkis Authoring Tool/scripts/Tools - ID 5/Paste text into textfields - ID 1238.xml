<Script>
	<ScriptReference id="1238" name="Paste text into textfields"></ScriptReference>
	<ObjectList membercount="7">
		<Step hash="EB71553181199CF9DCCD4D00F7D92747" id="89" name="# (comment)" enable="True">
			<Options>4</Options>
			<ParameterValues membercount="1">
				<Parameter type="Comment">
